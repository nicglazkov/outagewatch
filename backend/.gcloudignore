# Keep the Cloud Build source upload small. The Dockerfile only needs
# pyproject.toml, uv.lock, and src/ (see Dockerfile COPY lines), so everything
# below is dead weight in the upload and staging bucket. This file replaces
# gcloud's default .gitignore import, so list excludes explicitly.
.git/
.gitignore
.venv/
venv/
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
*.egg-info/
tests/
evals/
scripts/
